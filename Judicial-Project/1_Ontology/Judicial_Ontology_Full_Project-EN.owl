    <!-- =========================== -->
    <!-- 5-1-1. Experimental Group Verdicts -->
    <!-- =========================== -->

    <owl:NamedIndividual rdf:about="&onto;Verdict_EXP_001">
        <rdf:type rdf:resource="&onto;Verdict"/>
        <rdfs:label xml:lang="en">Verdict EXP 001</rdfs:label>
        <onto:hasVerdictDate rdf:datatype="&xsd;dateTime">2023-07-20T00:00:00</onto:hasVerdictDate>
